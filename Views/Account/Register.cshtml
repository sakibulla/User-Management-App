@model UserManagementApp.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-sm-10 col-md-6 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus-fill text-primary" style="font-size:2rem;"></i>
                    <h5 class="mt-2 fw-semibold">Create an account</h5>
                    <p class="text-muted small">Register to access the user management panel</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2" role="alert">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        <asp-validation-summary asp-validation-summary="All" class="d-inline mb-0" />
                    </div>
                }

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-medium">Full name</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="Name" class="form-control" type="text"
                                   placeholder="Your name" autocomplete="name" autofocus
                                   title="Enter your full name" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-medium">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" type="email"
                                   placeholder="you@example.com" autocomplete="email"
                                   title="Enter a valid email address — must be unique" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-medium">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" type="password"
                                   placeholder="Any password (even 1 character)" autocomplete="new-password"
                                   title="Choose any non-empty password" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                        <!-- NOTE: Per spec, even 1-character passwords are accepted -->
                        <div class="form-text small">Any non-empty password is accepted.</div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100"
                            title="Create your account — you can log in immediately after">
                        <i class="bi bi-person-check me-1"></i>Register
                    </button>
                </form>

                <hr class="my-3">
                <p class="text-center text-muted small mb-0">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</div>
