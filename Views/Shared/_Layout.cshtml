<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – User Management</title>

    <!-- Bootstrap 5 from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        /* NOTE: Professional/business aesthetic — minimal, clean, no animations */
        :root {
            --brand: #0d6efd;
        }
        body {
            background-color: #f8f9fa;
            font-size: 0.875rem;
        }
        .navbar-brand {
            font-weight: 600;
            letter-spacing: .03em;
        }
        /* IMPORTANT: Status badge colors */
        .badge-active    { background-color: #198754; }
        .badge-blocked   { background-color: #dc3545; }
        .badge-unverified{ background-color: #6c757d; }

        /* NOTE: Table row for blocked users gets strikethrough styling like the example */
        tr.user-blocked td { color: #6c757d; text-decoration: line-through; }
        tr.user-blocked td:first-child { text-decoration: none; } /* don't strike checkbox */

        /* NOTA BENE: No animations, no wallpapers — per assignment requirements */
        .toolbar-area {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 0.375rem 0.375rem 0 0;
            border-bottom: none;
            padding: 0.5rem 0.75rem;
        }
        .table-wrapper {
            border: 1px solid #dee2e6;
            border-radius: 0 0 0.375rem 0.375rem;
            overflow-x: auto;
        }
        .table {
            margin-bottom: 0;
            font-size: 0.875rem;
        }
        .table th {
            background-color: #f8f9fa;
            font-weight: 600;
            white-space: nowrap;
        }
        .table td, .table th {
            vertical-align: middle;
            padding: 0.5rem 0.75rem;
        }
        /* Align text properly per assignment */
        .col-check { width: 2rem; text-align: center; }
        .col-name  { min-width: 12rem; }
        .col-email { min-width: 14rem; }
        .col-status{ width: 8rem; text-align: center; }
        .col-login { width: 12rem; text-align: right; }
        .text-muted-small { font-size: 0.75rem; color: #6c757d; }

        /* Toast notification container */
        #toast-container {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            z-index: 1100;
            min-width: 280px;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Navigation bar — only shown when authenticated -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="/users">
                    <i class="bi bi-people-fill me-1"></i>UserAdmin
                </a>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="text-white-50 small">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm"
                                title="Sign out of your account">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </button>
                    </form>
                </div>
            </div>
        </nav>
    }

    <div class="container">
        <!-- Global flash messages from TempData -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <!-- Toast notifications (for async actions like block/delete) -->
    <div id="toast-container"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
